FROM python:3.12-slim

WORKDIR /app

# Install ecosim package + websockets
COPY server/pyproject.toml .
COPY server/ecosim/ ecosim/
RUN pip install --no-cache-dir ".[worker]"

# Copy browser visualizer and demo world
COPY client/browser/ viz/
COPY server/examples/demo_world.json .

ENV VIZ_DIR=/app/viz
ENV WORLD_FILE=/app/demo_world.json

EXPOSE 8001

CMD ["python", "-m", "ecosim.worker", "--host", "0.0.0.0", "--port", "8001"]
